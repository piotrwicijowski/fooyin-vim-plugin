{
  "$schema": "https://opencode.ai/tui.json",
  "keymap": {
    "leader": "ctrl+x",
    "leader_timeout": 2000,
    "sections": {
      "global": {
        "app.exit": "ctrl+c,<leader>q",
      },
      "session": {
        "session.half.page.up": "ctrl+u",
        "session.half.page.down": "ctrl+d",
      },
      "input": {
        "input.submit": "ctrl+return,alt+return",
        "input.newline": "return,shift+return",
        "input.delete.to.line.end": "ctrl+shift+k",
        "input.delete.to.line.start": "ctrl+shift+u",
      }
    }
  }
}
